{
  "Name": "ArmorRepair",
  "Enabled": true,
  "Version": "2.0-BEX",

  "Description": "Prevents mech armor from being replaced for free after each battle.<br>Also automates the repair of mechs and changes repair costs to be based on structure and armor types.",
  "Website": "https://github.com/AkiraBrahe/ArmorRepair",

  "DependsOn": [ "BT_Extended_Quirks" ],
  
  "DLL": "ArmorRepair.dll",

  "Settings": {
    "EnableAutoRepairPrompt": true,
    "AutoRepairMechsWithDestroyedComponents": true,
    "AutoRepairStructure": true,
    "ScaleStructureRepairTimeByTonnage": true,
    "PrototypeEndoFerroRepairCostMultiplier": 3.0,
    "ClanTechRepairCostMultiplier": 1.5,

    "StructureRepairCostByTag": [
      {
        "Tag": "chassis_endo",
        "WeightMultiplier": 0.5,
        "PPTMultiplier": 1.0,
        "TPCost": 2.0,
        "CBCost": 8.0
      }
    ],
    "ArmorRepairCostByTag": [
      {
        "Tag": "chassis_ferro",
        "WeightMultiplier": 1.0,
        "PPTMultiplier": 1.12,
        "TPCost": 1.5,
        "CBCost": 2.0
      }
    ]
  }
}