{
  "Name": "ArmorRepair",
  "Enabled": true,
  "Version": "1.7-BEX",

  "Description": "Prevents mech armor lost in combat from being replaced for free at the end of battle. Instead, create work orders to repair structure and armor damage, with costs based on type.",
  "Author": "Life",
  "Website": "https://github.com/citizenSnippy/ArmorRepair",
  
  "DLL": "ArmorRepair.dll",

  "Settings": {
    "EnableAutoRepairPrompt": true,
    "AutoRepairMechsWithDestroyedComponents": true,
    "AutoRepairStructure": true,
    "ScaleStructureRepairTimeByTonnage": true,

    "StructureRepairCostByTag": [
      {
        "Tag": "chassis_endo",
        "WeightMultiplier": 0.5,
        "TPCost": 2.0,
        "CBCost": 8.0
      }
    ],
    "ArmorRepairCostByTag": [
      {
        "Tag": "chassis_ferro",
        "WeightMultiplier": 1.0,
        "TPCost": 1.5,
        "CBCost": 2.0
      }
    ]
  }
}